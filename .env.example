# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=taskflow
POSTGRES_PASSWORD=taskflow_secret
POSTGRES_DB=taskflow

# Full connection string used by Go server (host=db refers to the docker-compose service name)
DATABASE_URL=postgres://taskflow:taskflow_secret@db:5432/taskflow?sslmode=disable

# ─── Backend ──────────────────────────────────────────────────────────────────
# REQUIRED: set a long random secret (do not use this example value as-is for anything public).
# Generate one with: openssl rand -hex 32
JWT_SECRET=dev-only-replace-with-openssl-rand-hex-32

SERVER_PORT=8080

# bcrypt cost factor — 12 is good for production, use 4-8 for test speed
BCRYPT_COST=12

# ─── Frontend ─────────────────────────────────────────────────────────────────
# Must be reachable FROM the user's browser (not from inside Docker)
VITE_API_URL=http://localhost:8080
